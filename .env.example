# ============================================================
# Terminal Blog - 站点配置
# 复制此文件为 .env 并修改相应值
# 或通过环境变量覆盖（在 Docker / CI/CD 中设置）
# ============================================================

# 网站标题（显示在浏览器标签和终端标题栏）
SITE_TITLE=TerminalBlog

# 欢迎语
WELCOME_MESSAGE=欢迎来到我的终端博客。这里用代码记录世界，用键盘书写思考。

# 网站地址（用于页脚链接显示，不带协议，如：example.com）
SITE_URL=

# ICP 备案号（留空则不显示）
ICP_NUMBER=