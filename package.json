{
  "name": "terminal-blog",
  "version": "1.0.0",
  "description": "终端风格博客 - Cloudflare Workers + KV（单文件 _worker.js）",
  "private": true,
  "scripts": {
    "build": "node scripts/build-worker.js",
    "dev": "wrangler dev --port 8788",
    "dev:pages": "wrangler pages dev public --kv BLOG_KV --port 8788",
    "deploy": "wrangler deploy",
    "deploy:pages": "wrangler pages deploy public --kv BLOG_KV",
    "seed": "node scripts/seed.js"
  },
  "devDependencies": {
    "wrangler": "^3.0.0"
  }
}